{
  "id": "empty_prompt",
  "name": "Work Mode Prompt Entry",
  "purpose": "Let user enter the initial task prompt for Work Mode.",
  "state": "idle",
  "visibleComponents": [
    "mode_selector",
    "empty_state_copy",
    "prompt_composer",
    "submit_button"
  ],
  "copy": {
    "emptyState": "Start with a prompt. Work Mode will create an editable plan before generating.",
    "composerPlaceholder": "How can I help you today?"
  },
  "fields": [
    {
      "id": "prompt",
      "type": "textarea",
      "required": true,
      "minLength": 1,
      "maxLength": 8000,
      "autosize": true
    }
  ],
  "clickActions": [
    {
      "id": "submit_work_prompt",
      "target": "submit_button",
      "preconditions": [
        "mode === 'work'",
        "prompt.trim().length > 0",
        "generationInProgress === false"
      ],
      "action": "callApi",
      "api": "POST /api/work-mode/analyze",
      "analyticsEvent": "prompt_submitted",
      "nextScreen": "analyzing_prompt",
      "nextState": "analyzing"
    },
    {
      "id": "clear_prompt",
      "target": "clear_button",
      "preconditions": ["prompt.length > 0"],
      "action": "clearPrompt",
      "nextState": "idle"
    }
  ],
  "keyboardActions": [
    {
      "keys": ["Enter"],
      "preconditions": ["prompt.trim().length > 0", "Shift is not pressed"],
      "action": "submit_work_prompt"
    },
    {
      "keys": ["Shift+Enter"],
      "action": "insertNewline"
    }
  ],
  "validation": [
    {
      "rule": "empty_prompt",
      "condition": "prompt.trim().length === 0",
      "message": "Enter a prompt to start Work Mode.",
      "blocksSubmit": true
    },
    {
      "rule": "too_long",
      "condition": "prompt.length > 8000",
      "message": "This prompt is too long for the prototype. Shorten it or move details into sources later.",
      "blocksSubmit": true
    }
  ],
  "edgeCases": [
    {
      "case": "user_pastes_large_prompt",
      "behavior": "Show length warning and disable submit above maxLength."
    },
    {
      "case": "backend_offline",
      "behavior": "Show recoverable error; do not expose OpenAI credentials in the browser."
    },
    {
      "case": "non_work_mode",
      "behavior": "Submit appends a normal chat message and sets state submitted instead of calling Work Mode APIs."
    }
  ]
}
