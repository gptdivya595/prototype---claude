{
  "id": "analyzing_prompt",
  "name": "Analyzing Prompt",
  "purpose": "Show that the system is detecting role, artifact, workflow, skill, modules, source mode, depth, and risk.",
  "state": "analyzing",
  "visibleComponents": [
    "prompt_preview",
    "analysis_progress",
    "backend_status_indicator"
  ],
  "progressMessages": [
    "Detecting role and artifact",
    "Matching workflow and skill",
    "Selecting suggested modules",
    "Checking source needs",
    "Estimating roadmap depth and risk"
  ],
  "apiCall": {
    "method": "POST",
    "path": "/api/work-mode/analyze",
    "timeoutMs": 20000,
    "abortableInCurrentUi": false,
    "successNextScreen": "detection_summary",
    "failureNextScreen": "errors_and_recovery"
  },
  "clickActions": [
    {
      "id": "cancel_analysis",
      "target": "cancel_analysis_button",
      "mvpStatus": "planned_not_implemented",
      "action": "abortRequest",
      "nextScreen": "empty_prompt",
      "nextState": "idle"
    }
  ],
  "successTransition": {
    "store": [
      "analysisId",
      "conversationId",
      "detectedRole",
      "detectedArtifact",
      "taskCategory",
      "intentCategory",
      "recommendedWorkflowId",
      "recommendedSkillId",
      "recommendedModuleIds",
      "selectedModuleIds",
      "sourceMode",
      "roadmapDepth",
      "riskLevel",
      "confidence",
      "confidenceBand",
      "matchedSignals",
      "alternatives",
      "questionsForUser",
      "candidates",
      "llm"
    ],
    "nextState": "reviewing_detection"
  },
  "failureHandling": [
    {
      "errorCode": "cors_origin_blocked | backend_unavailable",
      "message": "The backend is unavailable or blocked by CORS.",
      "actions": ["retry", "check_backend_url"]
    },
    {
      "errorCode": "rate_limited",
      "message": "Too many requests. Wait a moment and retry.",
      "actions": ["retry_later"]
    },
    {
      "errorCode": "validation_error | prompt_too_long | unsupported_mode",
      "message": "The prompt could not be analyzed. Edit it and try again.",
      "actions": ["edit_prompt"]
    }
  ],
  "analytics": {
    "onEnter": "prompt_submitted",
    "onSuccess": "analysis_completed",
    "onFailure": "analysis_failed"
  }
}
