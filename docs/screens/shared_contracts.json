{
  "id": "shared_contracts",
  "version": "0.1.0",
  "purpose": "Screen-level contract aligned to the current frontend and backend implementation.",
  "types": {
    "WorkModeUiState": [
      "idle",
      "submitted",
      "analyzing",
      "reviewing_detection",
      "choosing_suggestions",
      "editing_work_plan",
      "approved",
      "generating",
      "complete",
      "error"
    ],
    "GenerationStatus": ["idle", "generating", "cancelled", "complete", "failed"],
    "AutosaveStatus": ["idle", "saving", "saved", "failed"],
    "WorkPlanStatus": ["draft", "approved", "generated"],
    "WorkRole": [
      "Product Manager",
      "Researcher",
      "Developer",
      "Software Architect",
      "Data Analyst",
      "Founder",
      "Business Analyst",
      "Designer",
