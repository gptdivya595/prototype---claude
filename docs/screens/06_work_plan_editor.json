{
  "id": "work_plan_editor",
  "name": "Work Plan Editor",
  "purpose": "Let user edit the roadmap before approval.",
  "state": "editing_work_plan",
  "recordType": "WorkPlanRecord",
  "editableObject": "WorkPlanRecord.plan",
  "visibleComponents": [
    "work_plan_header",
    "save_status",
    "objective_editor",
    "assumptions_editor",
    "missing_context_editor",
    "section_editor_list",
    "validation_criteria_editor",
    "approval_bar"
  ],
  "editableFields": [
    "plan.objective",
    "plan.assumptions",
    "plan.missingContext",
    "plan.sections[].title",
    "plan.sections[].instructions",
    "plan.sections[].required",
    "plan.validationCriteria",
    "plan.selectedModuleIds",
    "plan.sourceMode"
  ],
  "protectedFields": [
    "workPlanId",
    "analysisId",
    "conversationId",
    "version",
    "approvedPlan",
    "status",
    "generatedOutputIds"
  ],
  "autosave": {
    "enabled": true,
    "debounceMs": 550,
    "api": "PATCH /api/work-mode/work-plans/:id",
    "requestShape": {
      "version": "WorkPlanRecord.version",
      "plan": "WorkPlanRecord.plan"
    },
    "states": ["idle", "saving", "saved", "failed"],
    "failureBehavior": "Keep local draft, show Save failed, allow retry.",
    "staleVersionBehavior": "Backend returns 409; UI should preserve local edits and offer reload/reapply."
  },
  "clickActions": [
    {
      "id": "edit_objective",
      "target": "objective_textarea",
      "action": "updatePlanField",
      "sideEffects": ["markDirty", "scheduleAutosave", "resetApprovalIfApproved"]
    },
    {
      "id": "add_assumption",
      "target": "add_assumption_button",
      "action": "appendListItem",
      "sideEffects": ["markDirty", "scheduleAutosave"]
    },
    {
      "id": "remove_assumption",
      "target": "remove_assumption_button",
      "action": "removeListItem",
      "sideEffects": ["markDirty", "scheduleAutosave"]
    },
    {
      "id": "add_missing_context",
      "target": "add_missing_context_button",
      "action": "appendListItem",
      "sideEffects": ["markDirty", "scheduleAutosave"]
    },
    {
      "id": "add_section",
      "target": "add_section_button",
      "action": "appendSection",
      "payload": {
        "required": false
      },
      "analyticsEvent": "workplan_section_added",
      "sideEffects": ["markDirty", "scheduleAutosave"]
    },
    {
      "id": "remove_section",
      "target": "remove_section_button",
      "action": "removeSection",
      "confirmation": {
        "showWhen": "section.required === true",
        "message": "This section is required. Convert it to optional before removing?"
      },
      "analyticsEvent": "workplan_section_removed",
      "sideEffects": ["markDirty", "scheduleAutosave"]
    },
    {
      "id": "move_section_up",
      "target": "move_up_button",
      "action": "reorderSection",
      "payload": { "direction": "up" },
      "analyticsEvent": "workplan_section_reordered",
      "sideEffects": ["markDirty", "scheduleAutosave"]
    },
    {
      "id": "move_section_down",
      "target": "move_down_button",
      "action": "reorderSection",
      "payload": { "direction": "down" },
      "analyticsEvent": "workplan_section_reordered",
      "sideEffects": ["markDirty", "scheduleAutosave"]
    },
    {
      "id": "retry_save",
      "target": "retry_save_button",
      "preconditions": ["autosaveStatus === 'failed'"],
      "action": "callApi",
      "api": "PATCH /api/work-mode/work-plans/:id"
    }
  ],
  "approvalBlockingValidation": [
    {
      "rule": "objective_required",
      "condition": "plan.objective.trim().length === 0",
      "message": "Objective is required."
    },
    {
      "rule": "at_least_one_section",
      "condition": "plan.sections.length === 0",
      "message": "At least one roadmap section is required."
    },
    {
      "rule": "required_section_title",
      "condition": "required section title is empty",
      "message": "Required sections need a title."
    },
    {
      "rule": "required_section_instructions",
      "condition": "required section instructions are empty",
      "message": "Required sections need instructions."
    },
    {
      "rule": "disabled_source_mode",
      "condition": "plan.sourceMode is user_uploaded or web_search while those features are disabled",
      "message": "Selected source mode is not enabled in the MVP."
    }
  ],
  "edgeCases": [
    {
      "case": "stale_version",
      "apiStatus": 409,
      "behavior": "Reload latest WorkPlanRecord and ask user to reapply local edits."
    },
    {
      "case": "edit_after_approval",
      "behavior": "Set status back to draft, clear approved snapshot in generation state, and show stale answer badge if an answer exists."
    },
    {
      "case": "browser_refresh_before_backend_persistence",
      "behavior": "Memory store data may be lost on backend restart; use GET /work-plans/:id only while the same backend process is alive."
    },
    {
      "case": "very_large_roadmap",
      "behavior": "Warn when section count exceeds 25 or total instruction text exceeds configured limit."
    }
  ]
}
