{
  "id": "generation_progress",
  "name": "Generation Progress",
  "purpose": "Show final answer generation progress, cancellation, and retry.",
  "state": "generating",
  "transport": {
    "current": "http_json",
    "sseImplemented": false,
    "webSocketImplemented": false,
    "futureUpgrade": "SSE can be added later for one-way answer token streaming."
  },
  "visibleComponents": [
    "approved_plan_snapshot_summary",
    "generation_spinner",
    "cancel_generation_button",
    "status_message"
  ],
  "apiCall": {
    "method": "POST",
    "path": "/api/work-mode/work-plans/:id/generate",
    "abortable": true,
    "timeoutMs": 90000,
    "requestShape": {
      "version": "approvedPlan.version"
    }
  },
  "clickActions": [
    {
      "id": "cancel_generation",
      "target": "cancel_generation_button",
      "action": "AbortController.abort",
      "analyticsEvent": "generation_cancelled",
      "nextState": "approved",
      "generationStatus": "cancelled"
    },
    {
      "id": "retry_generation",
      "target": "retry_generation_button",
      "preconditions": [
        "approvedPlan exists",
        "lastGenerationFailed === true || generationStatus === 'cancelled'"
      ],
      "action": "callApi",
      "api": "POST /api/work-mode/work-plans/:id/generate",
      "nextState": "generating"
    },
    {
      "id": "return_to_editor",
      "target": "return_to_editor_button",
      "action": "navigate",
      "nextScreen": "work_plan_editor",
      "nextState": "approved"
    }
  ],
  "successTransition": {
    "store": [
      "answerId",
      "answer",
      "validation",
      "llm",
      "createdAt"
    ],
    "nextScreen": "answer_and_validation",
    "nextState": "complete",
    "generationStatus": "complete",
    "analyticsEvent": "generation_completed"
  },
  "failureHandling": [
    {
      "case": "cancelled_by_user",
      "behavior": "Return main WorkModeUiState to approved. Do not mark Work Plan generated."
    },
    {
      "case": "openai_timeout",
      "behavior": "Show retry. Backend may return deterministic fallback when LLM answer is unavailable."
    },
    {
      "case": "validation_failed_after_answer",
      "behavior": "Show answer with validation warning instead of blank screen."
    },
    {
      "case": "client_disconnect_before_persist",
      "behavior": "Backend checks request abort before saving generated output."
    }
  ]
}
