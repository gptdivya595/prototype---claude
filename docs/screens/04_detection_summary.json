{
  "id": "detection_summary",
  "name": "Detection Summary",
  "purpose": "Let user review and override detected role, artifact, workflow, confidence, alternatives, and source mode before suggestions.",
  "state": "reviewing_detection",
  "visibleComponents": [
    "prompt_preview",
    "role_selector",
    "artifact_selector",
    "workflow_selector",
    "confidence_badge",
    "reason_panel",
    "source_mode_panel",
    "questions_panel",
    "alternative_workflows",
    "continue_button"
  ],
  "fields": [
    {
      "id": "roleOverride",
      "type": "select",
      "optionsRef": "WorkRole",
      "defaultFrom": "detectedRole"
    },
    {
      "id": "artifactOverride",
      "type": "select",
      "optionsRef": "WorkArtifact",
      "defaultFrom": "detectedArtifact"
    },
    {
      "id": "workflowOverride",
      "type": "select",
      "optionsRef": "WorkflowId",
      "defaultFrom": "recommendedWorkflowId"
    }
  ],
  "clickActions": [
    {
      "id": "change_role",
      "target": "role_selector",
      "action": "setRoleOverride",
      "analyticsEvent": "role_override_changed",
      "sideEffects": ["markDetectionOverridden"]
    },
    {
      "id": "change_artifact",
      "target": "artifact_selector",
      "action": "setArtifactOverride",
      "analyticsEvent": "artifact_override_changed",
      "sideEffects": ["recomputeWorkflowCandidatesInUiWhenSupported"]
    },
    {
      "id": "change_workflow",
      "target": "workflow_selector",
      "action": "setWorkflowOverride",
      "sideEffects": ["skillAndModuleDefaultsWillRefreshOnSuggestionsScreen"]
    },
    {
      "id": "select_alternative_workflow",
      "target": "alternative_workflow_item",
      "action": "setWorkflowOverride",
      "sideEffects": ["highlightSelectedWorkflow"]
    },
    {
      "id": "continue_to_suggestions",
      "target": "continue_button",
      "preconditions": [
        "analysisId exists",
        "selectedWorkflowId exists"
      ],
      "action": "navigate",
      "nextScreen": "skill_and_suggestions",
      "nextState": "choosing_suggestions"
    }
  ],
  "confidenceRules": [
    {
      "range": ">= 0.8",
      "label": "High confidence",
      "style": "success"
    },
    {
      "range": ">= 0.65 && < 0.8",
      "label": "Medium confidence",
      "style": "neutral"
    },
    {
      "range": "< 0.65",
      "label": "Low confidence",
      "style": "warning",
      "extraBehavior": "Show alternatives and ask user to confirm before continuing."
    }
  ],
  "displayRules": [
    {
      "id": "source_mode_notice",
      "behavior": "Show detected source mode and clarify that retrieval/web search is not connected in the current prototype."
    },
    {
      "id": "generic_fallback",
      "behavior": "If confidence is low or no specialized workflow wins, generic_workflow remains a valid selection."
    },
    {
      "id": "alternatives",
      "behavior": "Render alternatives as workflow choices with confidence and reason."
    }
  ],
  "edgeCases": [
    {
      "case": "unknown_role",
      "behavior": "Allow Unknown but require workflow selection before continuing."
    },
    {
      "case": "user_changes_artifact_to_incompatible_value",
      "behavior": "Allow continuation; suggestions screen will recompute skill/module defaults from workflow selection."
    },
    {
      "case": "low_confidence_no_alternatives",
      "behavior": "Show role/artifact/workflow selectors and allow manual continuation."
    }
  ]
}
