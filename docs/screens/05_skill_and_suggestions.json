{
  "id": "skill_and_suggestions",
  "name": "Skill And Suggestions",
  "purpose": "Let user select skill, modules, and source mode before Work Plan creation.",
  "state": "choosing_suggestions",
  "visibleComponents": [
    "skill_selector",
    "module_checklist",
    "source_mode_selector",
    "workflow_reason_panel",
    "create_work_plan_button",
    "back_to_detection_button"
  ],
  "dataSources": [
    {
      "id": "skills",
      "api": "GET /api/work-mode/skills",
      "returns": ["skills", "workflows", "modules", "roles", "artifacts", "sourceModes", "riskLevels", "roadmapDepthLevels", "plannedWorkflowIds", "transport"]
    },
    {
      "id": "analysis",
      "source": "POST /api/work-mode/analyze response"
    }
  ],
  "fields": [
    {
      "id": "selectedSkillId",
      "type": "select_cards",
      "required": true,
      "optionsRef": "SkillId"
    },
    {
      "id": "selectedModuleIds",
      "type": "checkbox_group",
      "required": false,
      "optionsRef": "ModuleId"
    },
    {
      "id": "sourceMode",
      "type": "segmented_control",
      "options": ["none", "source_needed_only", "user_uploaded", "web_search"],
      "disabledOptions": ["user_uploaded", "web_search"],
      "defaultFrom": "analysis.sourceMode"
    }
  ],
  "implementedSkills": [
    "investor_deck_builder",
    "prd_builder",
    "bug_fix_planner",
    "backend_api_builder",
    "frontend_app_builder",
    "architecture_reviewer",
    "research_synthesizer",
    "analytics_planner",
    "complex_code_planner",
    "career_path_coach",
    "general_workflow_planner"
  ],
  "clickActions": [
    {
      "id": "change_skill",
      "target": "skill_selector.card",
      "action": "setSelectedSkill",
      "analyticsEvent": "skill_changed",
      "sideEffects": [
        "updateWorkflowFromSkill",
        "recomputeDefaultModules",
        "preserveCompatibleManualModules",
        "showSuggestionsUpdatedNotice"
      ]
    },
    {
      "id": "toggle_module",
      "target": "module_checkbox",
      "action": "toggleModule",
      "analyticsEvent": "module_toggled",
      "sideEffects": ["markModuleAsManuallyChanged"]
    },
    {
      "id": "change_source_mode",
      "target": "source_mode_selector",
      "action": "setSourceMode",
      "analyticsEvent": "source_mode_changed"
    },
    {
      "id": "create_work_plan",
      "target": "create_work_plan_button",
      "preconditions": [
        "analysisId exists",
        "selectedSkillId exists",
        "sourceMode is enabled",
        "selectedModuleIds contains only known ModuleId values"
      ],
      "action": "callApi",
      "api": "POST /api/work-mode/work-plans",
      "requestShape": {
        "analysisId": "analysisId",
        "roleOverride": "roleOverride | null",
        "artifactOverride": "artifactOverride | null",
        "workflowOverride": "workflowOverride | null",
        "skillOverride": "selectedSkillId",
        "selectedModuleIds": "selectedModuleIds",
        "sourceMode": "sourceMode"
      },
      "nextScreen": "work_plan_editor",
      "nextState": "editing_work_plan"
    },
    {
      "id": "back_to_detection",
      "target": "back_to_detection_button",
      "action": "navigate",
      "nextScreen": "detection_summary",
      "nextState": "reviewing_detection"
    }
  ],
  "warnings": [
    {
      "id": "source_needed_warning",
      "condition": "sourceHeavyPrompt === true && sourceMode === 'none'",
      "message": "This task likely needs evidence. Claims may be marked unverified if sources are not enabled."
    },
    {
      "id": "web_search_disabled",
      "condition": "sourceMode === 'web_search' && webSearchEnabled === false",
      "message": "Live web search is not enabled. Use Source needed instead."
    },
    {
      "id": "ambiguous_prompt_fallback",
      "condition": "confidence < 0.65 || no specialized workflow wins",
      "message": "Use general_workflow_planner and generic_workflow so the user can still edit a neutral roadmap."
    }
  ],
  "ownershipRules": {
    "recommendedModuleIds": "From analyze endpoint; used as default suggestions.",
    "selectedModuleIds": "Owned by user after this screen; sent to create Work Plan.",
    "workflowOverride": "Can be changed by role/artifact/skill overrides before Work Plan creation."
  }
}
