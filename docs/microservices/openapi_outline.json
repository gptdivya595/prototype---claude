{
  "openapi": "3.0.3",
  "info": {
    "title": "Work Mode API",
    "version": "0.1.0",
    "description": "Prototype API outline for the currently implemented Work Mode HTTP JSON backend."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8787/api/work-mode",
      "description": "Local development"
    },
    {
      "url": "https://your-render-service.onrender.com/api/work-mode",
      "description": "Render production backend"
    }
  ],
  "transport": {
    "current": "http_json",
    "sseStreaming": false,
    "webSocket": false
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Service health, feature flags, model config, route list, and transport flags"
          }
        }
      }
    },
    "/skills": {
      "get": {
        "summary": "List Work Mode skills, workflows, modules, roles, artifacts, and transport flags",
        "responses": {
          "200": {
            "description": "Skill catalog and taxonomy"
          }
        }
      }
    },
    "/analyze": {
      "post": {
        "summary": "Analyze prompt",
        "requestBody": {
          "description": "conversationId, mode=work, prompt"
        },
        "responses": {
          "200": {
            "description": "Prompt analysis with detected role, artifact, workflow, skill, modules, confidence, alternatives, depth, risk, source mode, and LLM metadata"
          },
          "400": {
            "description": "validation_error, prompt_too_long, or unsupported_mode"
          },
          "401": {
            "description": "demo_token_required when demo token is configured"
          },
          "429": {
            "description": "rate_limit_exceeded"
          }
        }
      }
    },
    "/work-plans": {
      "post": {
        "summary": "Create Work Plan",
        "responses": {
          "200": {
            "description": "Draft WorkPlanRecord"
          },
          "400": {
            "description": "Invalid override, unknown module, unknown workflow, or skill/workflow mismatch"
          },
          "404": {
            "description": "analysis_not_found"
          }
        }
      }
    },
    "/work-plans/{id}": {
      "get": {
        "summary": "Get Work Plan",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "WorkPlanRecord"
          },
          "404": {
            "description": "work_plan_not_found"
          }
        }
      },
      "patch": {
        "summary": "Update Work Plan",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Updated WorkPlanRecord"
          },
          "409": {
            "description": "stale_work_plan_version"
          },
          "422": {
            "description": "invalid_work_plan"
          }
        }
      }
    },
    "/work-plans/{id}/approve": {
      "post": {
        "summary": "Approve Work Plan",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Approved WorkPlanRecord"
          },
          "409": {
            "description": "stale_work_plan_version or work_plan_not_draft"
          },
          "422": {
            "description": "invalid_work_plan"
          }
        }
      }
    },
    "/work-plans/{id}/generate": {
      "post": {
        "summary": "Generate final answer",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Generated answer, validation result, and LLM metadata"
          },
          "409": {
            "description": "generate_before_approval or stale_work_plan_version"
          },
          "500": {
            "description": "Unhandled generation failure"
          }
        }
      }
    }
  },
  "futureOnlyPaths": {
    "/work-plans/{id}/generate-stream": {
      "status": "not_implemented",
      "transport": "sse",
      "description": "Potential future endpoint for one-way token streaming."
    },
    "/ws/work-mode": {
      "status": "not_implemented",
      "transport": "websocket",
      "description": "Potential future endpoint for collaborative editing or bidirectional tool control."
    }
  }
}
