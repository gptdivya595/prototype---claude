{
  "version": "0.1.0",
  "purpose": "How the frontend integrates with the Work Mode microservice.",
  "frontendClient": {
    "name": "workModeClient",
    "baseUrlEnv": "VITE_WORK_MODE_API_BASE",
    "headers": {
      "Content-Type": "application/json",
      "X-Demo-Token": "optional when DEMO_API_TOKEN is enabled"
    },
    "methods": [
      "health",
      "listSkills",
      "analyzePrompt",
      "createWorkPlan",
      "getWorkPlan",
      "updateWorkPlan",
      "approveWorkPlan",
      "generateAnswer",
      "generateAnswerStream"
    ]
  },
  "stateMapping": [
    {
      "uiState": "idle",
      "screen": "empty_prompt",
      "availableActions": ["submitPrompt", "changeMode", "openSettings"]
    },
    {
      "uiState": "analyzing",
      "screen": "analyzing_prompt",
      "apiInFlight": "POST /api/work-mode/analyze",
      "availableActions": ["cancelAnalysis"]
    },
    {
      "uiState": "reviewing_detection",
      "screen": "detection_summary",
      "requiredData": ["analysisId", "detectedRole", "detectedArtifact", "recommendedSkillId"],
      "availableActions": ["changeRoleOverride", "changeArtifactOverride", "changeSkill", "continueToSuggestions"]
    },
    {
      "uiState": "choosing_suggestions",
      "screen": "skill_and_suggestions",
      "apiNeeded": "GET /api/work-mode/skills",
      "availableActions": ["changeSkill", "toggleModule", "changeSourceMode", "createWorkPlan"]
    },
    {
      "uiState": "editing_plan",
      "screen": "work_plan_editor",
      "requiredData": ["WorkPlanRecord"],
      "availableActions": ["editWorkPlanField", "addSection", "removeSection", "reorderSection", "approveWorkPlan"],
      "backgroundActions": ["autosaveWorkPlan"]
    },
    {
      "uiState": "approved",
      "screen": "approval_bar",
      "requiredData": ["WorkPlanRecord.approvedPlan"],
      "availableActions": ["generateAnswer", "editWorkPlanField"]
    },
    {
      "uiState": "generating",
      "screen": "generation_progress",
      "apiInFlight": "POST /api/work-mode/work-plans/:id/generate",
      "availableActions": ["cancelGeneration"]
    },
    {
      "uiState": "complete",
      "screen": "answer_and_validation",
      "requiredData": ["answer", "validation"],
      "availableActions": ["copyAnswer", "editPlan", "regenerate", "exportAnswer"]
    },
    {
      "uiState": "error",
      "screen": "errors_and_recovery",
      "availableActions": ["retryFailedAction", "returnToEditor", "returnToPrompt"]
    }
  ],
  "autosave": {
    "enabled": true,
    "debounceMs": 550,
    "api": "PATCH /api/work-mode/work-plans/:id",
    "request": {
      "version": "record.version",
      "plan": "record.plan without UI-only id/status/version fields"
    },
    "successBehavior": "Replace local WorkPlanRecord with server response.",
    "staleVersionBehavior": "Show stale version error, fetch latest record, ask user to reapply edits.",
    "networkFailureBehavior": "Keep local draft and show Save failed."
  },
  "abortBehavior": {
    "analyze": "Not implemented in the current UI; can be added with AbortController later.",
    "generate": "AbortController cancels the HTTP request. SSE is still deferred.",
    "backendRequirement": "Current route checks for client disconnect before persisting generated output."
  },
  "websocketDecision": {
    "useWebSocketInMvp": false,
    "reason": "No realtime collaborative editing or bidirectional tool control is needed.",
    "useInstead": ["HTTP", "Optional SSE for generation streaming"]
  },
  "frontendErrors": {
    "BACKEND_UNAVAILABLE": "Show retry and keep local editing available.",
    "STALE_WORK_PLAN_VERSION": "Reload latest plan and preserve local edits where possible.",
    "GENERATE_BEFORE_APPROVAL": "Return to approval bar.",
    "RATE_LIMITED": "Show wait and retry later.",
    "OPENAI_UNAVAILABLE": "Show fallback or retry."
  }
}
