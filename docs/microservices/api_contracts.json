{
  "version": "0.1.0",
  "basePath": "/api/work-mode",
  "transport": {
    "current": "http_json",
    "sseStreaming": false,
    "webSocket": false
  },
  "implementationSourceOfTruth": [
    "backend/routes/workMode.ts",
    "backend/schemas/workModeSchemas.ts",
    "backend/types/workMode.ts",
    "backend/templates/registries.ts",
    "backend/templates/workflows.ts"
  ],
  "apiEnvelope": {
    "success": {
      "ok": true,
      "data": "T",
      "requestId": "string"
    },
    "error": {
      "ok": false,
      "error": {
        "code": "string",
        "message": "string",
        "details": "unknown"
      },
      "requestId": "string"
    }
  },
  "endpoints": [
    {
      "id": "health",
      "method": "GET",
      "path": "/health",
      "auth": "none_or_demo_token",
      "purpose": "Check service health, route availability, model flags, and transport capabilities.",
      "request": null,
      "response": {
        "status": "healthy",
        "namespace": "work-mode",
        "implementedPhase": 12,
        "availableRoutes": [
          "/api/work-mode/health",
          "/api/work-mode/skills",
          "/api/work-mode/analyze",
          "/api/work-mode/work-plans",
          "/api/work-mode/work-plans/:id",
          "PATCH /api/work-mode/work-plans/:id",
          "POST /api/work-mode/work-plans/:id/approve",
          "POST /api/work-mode/work-plans/:id/generate"
        ],
        "analysisCount": "number",
        "workPlanCount": "number",
        "generatedOutputCount": "number",
        "openAiConfigured": "boolean",
        "models": "safe model config without secrets",
        "circuits": "OpenAI circuit breaker states",
        "features": {
          "llmClassifier": "boolean",
          "llmWorkPlan": "boolean",
          "llmAnswer": "boolean",
          "sseStreaming": false,
          "webSocket": false,
          "persistence": "memory",
          "durablePersistence": false
        },
        "llmFlags": {
          "classifier": "boolean",
          "workPlan": "boolean",
          "answer": "boolean"
        }
      },
      "frontendUsage": "Backend status indicator and deployment smoke check."
    },
    {
      "id": "list_skills",
      "method": "GET",
      "path": "/skills",
      "auth": "none_or_demo_token",
      "purpose": "Return available Work Mode skills, workflows, modules, roles, artifacts, and transport flags.",
      "request": null,
      "response": {
        "skills": [
          {
            "id": "investor_deck_builder",
            "workflowId": "slide_deck"
          },
          {
            "id": "prd_builder",
            "workflowId": "prd_generation"
          },
          {
            "id": "bug_fix_planner",
            "workflowId": "debugging_bug_fix"
          },
          {
            "id": "backend_api_builder",
            "workflowId": "backend_software"
          },
          {
            "id": "frontend_app_builder",
            "workflowId": "frontend_web"
          },
          {
            "id": "architecture_reviewer",
            "workflowId": "architecture_review"
          },
          {
            "id": "research_synthesizer",
            "workflowId": "research_report"
          },
          {
            "id": "analytics_planner",
            "workflowId": "analytics_plan"
          },
          {
            "id": "complex_code_planner",
            "workflowId": "complex_coding"
          },
          {
            "id": "career_path_coach",
            "workflowId": "career_path"
          },
          {
            "id": "general_workflow_planner",
            "workflowId": "generic_workflow"
          }
        ],
        "workflows": ["WorkflowDefinition"],
        "modules": ["ModuleDefinition"],
        "roles": ["WorkRole"],
        "artifacts": ["WorkArtifact"],
        "sourceModes": ["none", "source_needed_only", "user_uploaded", "web_search"],
        "riskLevels": ["low", "medium", "high", "restricted"],
        "roadmapDepthLevels": ["L1", "L2", "L3", "L4"],
        "plannedWorkflowIds": ["competitive_analysis", "brd_generation", "strategy_memo", "career_transition_plan"],
        "transport": {
          "mode": "http",
          "webSocket": false,
          "sseStreaming": false
        }
      },
      "frontendUsage": "Skill selector, module checklist, taxonomy source, and settings panel."
    },
    {
      "id": "analyze_prompt",
      "method": "POST",
      "path": "/analyze",
      "auth": "none_or_demo_token",
      "purpose": "Detect role, artifact, workflow, skill, modules, confidence, roadmap depth, risk, and source mode.",
      "request": {
        "conversationId": "string, default local",
        "mode": "work",
        "prompt": "string, required, max 8000 chars"
      },
      "response": {
        "analysisId": "string",
        "conversationId": "string",
        "mode": "work",
        "detectedRole": "WorkRole",
        "detectedArtifact": "WorkArtifact",
        "taskCategory": "string",
        "intentCategory": "string",
        "confidence": "number 0..1",
        "confidenceBand": "high | medium | low",
        "recommendedWorkflowId": "WorkflowId",
        "recommendedSkillId": "SkillId",
        "recommendedModuleIds": ["ModuleId"],
        "selectedModuleIds": ["ModuleId"],
        "sourceMode": "SourceMode",
        "roadmapDepth": "RoadmapDepth",
        "riskLevel": "RiskLevel",
        "reason": "string",
        "matchedSignals": ["string"],
        "alternatives": [
          {
            "value": "WorkflowId",
            "score": "number",
            "matchedSignals": ["string"]
          }
        ],
        "questionsForUser": ["string"],
        "candidates": {
          "roles": ["Candidate<WorkRole>"],
          "artifacts": ["Candidate<WorkArtifact>"],
          "modules": ["Candidate<ModuleId>"],
          "workflows": ["Candidate<WorkflowId>"]
        },
        "llm": {
          "classifier": "LlmCallMetadata"
        },
        "createdAt": "ISODate"
      },
      "frontendUsage": "Detection summary screen.",
      "notes": [
        "recommendedModuleIds are the detected recommendations.",
        "selectedModuleIds are the modules that should be preselected for user editing.",
        "If LLM classification is enabled and fails, the backend reconciles back to deterministic detection.",
        "Ambiguous prompts fall back to generic_workflow and general_workflow_planner."
      ],
      "errorCases": [
        {
          "status": 400,
          "code": "validation_error",
          "meaning": "Prompt is blank or invalid."
        },
        {
          "status": 400,
          "code": "prompt_too_long",
          "meaning": "Prompt exceeds 8000 characters."
        },
        {
          "status": 400,
          "code": "unsupported_mode",
          "meaning": "Only mode=work is accepted."
        }
      ]
    },
    {
      "id": "create_work_plan",
      "method": "POST",
      "path": "/work-plans",
      "auth": "none_or_demo_token",
      "purpose": "Create draft WorkPlanRecord from saved analysis and user selections.",
      "request": {
        "analysisId": "string",
        "roleOverride": "WorkRole | null",
        "artifactOverride": "WorkArtifact | null",
        "workflowOverride": "WorkflowId | null",
        "skillOverride": "SkillId | null",
        "selectedModuleIds": ["ModuleId"],
        "sourceMode": "SourceMode | null"
      },
      "response": {
        "workPlanId": "string",
        "conversationId": "string",
        "analysisId": "string",
        "status": "draft",
        "version": 1,
        "plan": "WorkPlan",
        "approvedPlan": null,
        "generatedOutputIds": [],
        "llm": {
          "workPlan": "LlmCallMetadata"
        },
        "createdAt": "ISODate",
        "updatedAt": "ISODate"
      },
      "frontendUsage": "Work Plan editor initial data.",
      "errorCases": [
        {
          "status": 404,
          "code": "analysis_not_found",
          "meaning": "analysisId was not found in memory store."
        },
        {
          "status": 400,
          "code": "unknown_workflow_id | unknown_module_id | validation_error",
          "meaning": "Override or selected module is not in the registry."
        },
        {
          "status": 400,
          "code": "skill_workflow_mismatch",
          "meaning": "Skill override does not belong to selected workflow."
        }
      ]
    },
    {
      "id": "get_work_plan",
      "method": "GET",
      "path": "/work-plans/:id",
      "auth": "none_or_demo_token",
      "purpose": "Fetch latest WorkPlanRecord while the memory store still has it.",
      "request": null,
      "response": "WorkPlanRecord",
      "frontendUsage": "Available for stale-version recovery or refresh restore; current React client does not call it yet.",
      "errorCases": [
        {
          "status": 404,
          "code": "work_plan_not_found",
          "meaning": "Record does not exist in current backend memory."
        }
      ]
    },
    {
      "id": "update_work_plan",
      "method": "PATCH",
      "path": "/work-plans/:id",
      "auth": "none_or_demo_token",
      "purpose": "Autosave user edits to draft Work Plan.",
      "request": {
        "version": "number",
        "plan": "WorkPlan"
      },
      "response": "WorkPlanRecord",
      "frontendUsage": "Autosave and retry save.",
      "errorCases": [
        {
          "status": 409,
          "code": "stale_work_plan_version",
          "meaning": "Client version is older than server version."
        },
        {
          "status": 422,
          "code": "invalid_work_plan",
          "meaning": "Plan payload failed schema validation."
        }
      ]
    },
    {
      "id": "approve_work_plan",
      "method": "POST",
      "path": "/work-plans/:id/approve",
      "auth": "none_or_demo_token",
      "purpose": "Freeze draft plan into approved snapshot.",
      "request": {
        "version": "number"
      },
      "response": "WorkPlanRecord",
      "frontendUsage": "Approval bar.",
      "preconditions": [
        "Work Plan exists",
        "status is draft",
        "required sections are valid",
        "client version is current"
      ],
      "errorCases": [
        {
          "status": 409,
          "code": "stale_work_plan_version | work_plan_not_draft",
          "meaning": "Plan is stale or not approvable."
        },
        {
          "status": 422,
          "code": "invalid_work_plan",
          "meaning": "Approval validation failed."
        }
      ]
    },
    {
      "id": "generate_answer",
      "method": "POST",
      "path": "/work-plans/:id/generate",
      "auth": "none_or_demo_token",
      "purpose": "Generate final answer from approvedPlan snapshot.",
      "request": {
        "version": "number | optional"
      },
      "response": {
        "answerId": "string",
        "workPlanId": "string",
        "generatedFromVersion": "number",
        "answer": "string",
        "validation": "ValidationResult",
        "llm": {
          "answer": "LlmCallMetadata"
        },
        "createdAt": "ISODate"
      },
      "frontendUsage": "Generation progress and answer screen.",
      "preconditions": [
        "Work Plan status is approved or generated",
        "approvedPlan exists",
        "optional version matches current record version"
      ],
      "cancellationBehavior": "If the client aborts before persistence, backend returns no output and does not mark the Work Plan generated.",
      "errorCases": [
        {
          "status": 409,
          "code": "generate_before_approval",
          "meaning": "Work Plan has not been approved."
        },
        {
          "status": 409,
          "code": "stale_work_plan_version",
          "meaning": "Provided version is stale."
        }
      ]
    }
  ],
  "notImplementedEndpoints": [
    {
      "id": "generate_answer_stream",
      "path": "/work-plans/:id/generate-stream",
      "status": "future_only",
      "reason": "No backend SSE route or React streaming client exists in the current prototype."
    },
    {
      "id": "work_mode_websocket",
      "path": "/ws/work-mode",
      "status": "future_only",
      "reason": "No collaborative realtime editing or bidirectional tool control exists in the MVP."
    }
  ],
  "sharedTypes": {
    "WorkPlan": {
      "prompt": "string",
      "role": "WorkRole",
      "artifact": "WorkArtifact",
      "workflowId": "WorkflowId",
      "skillId": "SkillId",
      "objective": "string",
      "audience": "string | undefined",
      "sourceMode": "SourceMode",
      "roadmapDepth": "RoadmapDepth",
      "riskLevel": "RiskLevel",
      "assumptions": ["string"],
      "missingContext": ["string"],
      "sections": ["WorkPlanSection"],
      "suggestions": ["WorkPlanSuggestion"],
      "validationCriteria": ["string"],
      "selectedModuleIds": ["ModuleId"]
    },
    "WorkPlanSection": {
      "id": "string",
      "title": "string",
      "instructions": "string",
      "required": "boolean",
      "moduleId": "ModuleId | optional",
      "sourceRefs": ["string"]
    },
    "ValidationResult": {
      "matchesApprovedPlan": "boolean",
      "missingSections": ["string"],
      "unsupportedClaims": ["string"],
      "qualityScore": "number 0..100",
      "recommendedFixes": ["string"],
      "sourceNeededClaims": ["string"],
      "passedChecks": ["string"]
    },
    "LlmCallMetadata": {
      "attempted": "boolean",
      "provider": "deterministic | local | openai | fallback",
      "model": "string | optional",
      "latencyMs": "number | optional",
      "fallbackUsed": "boolean",
      "fallbackReason": "string | optional"
    }
  }
}
