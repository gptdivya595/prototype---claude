  "fallbackRules": [
    {
      "case": "no candidate scores above zero",
      "workflowId": "generic_workflow",
      "skillId": "general_workflow_planner"
    },
    {
      "case": "prompt is cross-functional or ambiguous",
      "workflowId": "generic_workflow",
      "skillId": "general_workflow_planner"
    },
    {
      "case": "LLM returns unknown role/artifact/workflow/module",
      "behavior": "Discard invalid LLM value and use deterministic allowed-registry value."
    }
  ],
  "productDecision": {
    "implementedRoadmapTypes": 11,
    "plannedWorkflowIds": 4,
    "laterIdeaCount": 6,
    "mvpIdentificationFields": 11,
    "roadmapDetailLevels": 4,
    "fallbackWorkflow": "generic_workflow"
  }
}
