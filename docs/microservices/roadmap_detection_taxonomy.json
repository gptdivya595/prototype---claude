{
  "version": "0.1.0",
  "purpose": "Canonical taxonomy for Work Mode system identification, roadmap depth, fallback behavior, and supported roadmap types.",
  "identificationFields": [
    {
      "id": "detectedRole",
      "requiredForMvp": true,
      "values": [
        "Product Manager",
        "Researcher",
        "Developer",
        "Software Architect",
        "Data Analyst",
        "Founder",
        "Business Analyst",
        "Designer",
        "Marketer",
        "Executive",
        "Career Coach",
        "Unknown"
      ]
    },
    {
      "id": "detectedArtifact",
      "requiredForMvp": true,
      "values": [
        "Code",
        "PRD",
        "BRD",
        "PPT",
        "Research Report",
        "Strategy Memo",
        "Competitive Analysis",
        "Technical Design",
        "Architecture Review",
        "Backend API",
        "Frontend App",
        "Data Analysis",
        "Career Roadmap",
        "Implementation Plan",
        "General Roadmap",
        "Unknown"
      ]
    },
    {
      "id": "taskCategory",
      "requiredForMvp": true,
      "values": [
        "presentation",
        "product",
        "business",
        "engineering",
        "backend",
        "frontend",
        "technical_design",
        "research",
        "analysis",
        "data",
        "career",
        "general"
      ]
    },
    {
      "id": "intentCategory",
      "requiredForMvp": true,
      "values": [
        "planning",
        "drafting",
        "debugging",
        "research",
        "analysis",
        "decision_support",
        "implementation",
        "review",
        "coaching"
      ]
    },
    {
      "id": "recommendedWorkflowId",
      "requiredForMvp": true,
      "values": [
        "slide_deck",
        "prd_generation",
        "debugging_bug_fix",
        "backend_software",
        "frontend_web",
        "architecture_review",
        "research_report",
        "analytics_plan",
        "complex_coding",
        "career_path",
        "generic_workflow"
      ]
    },
    {
      "id": "recommendedSkillId",
      "requiredForMvp": true,
      "values": [
        "investor_deck_builder",
        "prd_builder",
        "bug_fix_planner",
        "backend_api_builder",
        "frontend_app_builder",
        "architecture_reviewer",
        "research_synthesizer",
        "analytics_planner",
        "complex_code_planner",
        "career_path_coach",
        "general_workflow_planner"
      ]
    },
    {
      "id": "recommendedModuleIds",
      "requiredForMvp": true,
      "values": [
        "assumptions",
        "competitor_analysis",
        "investor_framing",
        "sources_required",
        "root_cause_analysis",
        "test_cases",
        "metrics",
        "user_personas",
        "validation_checklist",
        "risk_analysis",
        "implementation_plan",
        "market_landscape",
        "api_examples",
        "database_schema",
        "tradeoff_analysis"
      ]
    },
    {
      "id": "confidence",
      "requiredForMvp": true,
      "range": [0, 1]
    },
    {
      "id": "confidenceBand",
      "requiredForMvp": true,
      "values": ["high", "medium", "low"]
    },
    {
      "id": "sourceMode",
      "requiredForMvp": true,
      "values": ["none", "source_needed_only", "user_uploaded", "web_search"],
      "currentUiEnabledValues": ["none", "source_needed_only"]
    },
    {
      "id": "roadmapDepth",
      "requiredForMvp": true,
      "values": ["L1", "L2", "L3", "L4"]
    },
    {
      "id": "riskLevel",
      "requiredForMvp": true,
      "values": ["low", "medium", "high", "restricted"]
    },
    {
      "id": "audience",
      "requiredForMvp": false
    },
    {
      "id": "entities",
      "requiredForMvp": false
    }
  ],
  "detectionPipeline": [
    {
      "step": 1,
      "name": "normalize_prompt",
      "owner": "PromptNormalizer",
      "output": ["trimmedText", "lowerText", "tokens", "phrases", "explicitArtifactHints", "audienceHints", "entityHints", "sourceHints", "riskHints"]
    },
    {
      "step": 2,
      "name": "score_registries",
      "owner": "DeterministicDetector",
      "output": ["role candidates", "artifact candidates", "module candidates", "sourceMode", "riskLevel", "roadmapDepth"]
    },
    {
      "step": 3,
      "name": "pick_workflow",
      "owner": "WorkflowPicker",
      "output": ["recommendedWorkflowId", "recommendedSkillId", "workflowCandidates", "alternatives"]
    },
    {
      "step": 4,
      "name": "optional_llm_classifier",
      "owner": "LlmClassifier",
      "condition": "USE_LLM_CLASSIFIER=true and OPENAI_API_KEY exists",
      "output": "structured classification constrained to allowed registries"
    },
    {
      "step": 5,
      "name": "reconcile_and_fallback",
      "owner": "LlmReconciler",
      "output": "validated PromptAnalysis; deterministic fallback if LLM fails or returns invalid fields"
    }
  ],
  "confidenceBands": [
    {
      "id": "high",
      "min": 0.8,
      "behavior": "Auto-select workflow, skill, modules, depth, risk, and source mode while allowing override."
    },
    {
      "id": "medium",
      "min": 0.65,
      "maxExclusive": 0.8,
      "behavior": "Show recommendation plus alternatives."
    },
    {
      "id": "low",
      "maxExclusive": 0.65,
      "behavior": "Show warning, questions, alternatives, and keep generic_workflow available."
    }
  ],
  "roadmapDepthLevels": [
    {
      "id": "L1",
      "label": "Light Roadmap",
      "sectionCount": "3-5",
      "useWhen": ["short prompt", "quick draft", "low context"]
    },
    {
      "id": "L2",
      "label": "Standard Work Plan",
      "sectionCount": "6-10",
      "useWhen": ["normal PRD", "normal deck", "normal bug fix", "career path"]
    },
    {
      "id": "L3",
      "label": "Deep Work Plan",
      "sectionCount": "10-16",
      "useWhen": ["competitors", "investors", "technical feasibility", "source-heavy", "multi-stakeholder", "backend/frontend build"]
    },
    {
      "id": "L4",
      "label": "Enterprise Roadmap",
      "sectionCount": "16-25",
      "useWhen": ["high-stakes", "multi-team", "compliance", "security", "financial", "medical", "legal", "architecture review"]
    }
  ],
  "roadmapTypes": {
    "implemented": [
      {
        "workflowId": "slide_deck",
        "skillId": "investor_deck_builder",
        "label": "Investor / Slide Deck Roadmap",
        "defaultDepth": "L3",
        "primaryArtifacts": ["PPT", "Strategy Memo", "Competitive Analysis", "Research Report"],
        "primaryRoles": ["Founder", "Researcher", "Product Manager", "Executive"]
      },
      {
        "workflowId": "prd_generation",
        "skillId": "prd_builder",
        "label": "Product Requirements Roadmap",
        "defaultDepth": "L2",
        "primaryArtifacts": ["PRD", "BRD", "Technical Design", "Strategy Memo"],
        "primaryRoles": ["Product Manager", "Founder", "Business Analyst", "Designer"]
      },
      {
        "workflowId": "debugging_bug_fix",
