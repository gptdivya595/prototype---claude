        "label": "Backend Software Roadmap",
        "defaultDepth": "L3",
        "primaryArtifacts": ["Backend API", "Code", "Technical Design", "Implementation Plan"],
        "primaryRoles": ["Developer", "Software Architect"]
      },
      {
        "workflowId": "frontend_web",
        "skillId": "frontend_app_builder",
        "label": "Frontend Web Roadmap",
        "defaultDepth": "L3",
        "primaryArtifacts": ["Frontend App", "Code", "Technical Design", "Implementation Plan"],
        "primaryRoles": ["Developer", "Designer", "Product Manager"]
      },
      {
